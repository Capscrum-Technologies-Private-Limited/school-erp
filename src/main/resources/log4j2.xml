<?xml version="1.0" encoding="UTF-8" ?>

<Configuration>
    <Appenders>
        <Console name="Console">
            <PatternLayout
                    pattern="[%style{%date{DEFAULT}}{yellow}] %highlight{%-5level}{FATAL=bg_red, ERROR=red, WARN=yellow, INFO=green %c{1.1.1* }>>%msg%n"/>
        </Console>
    </Appenders>

    <Loggers>
        <Root level="INFO">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>